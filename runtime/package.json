{
  "name": "floe-runtime",
  "version": "0.1.0",
  "description": "Runtime MCP server and provider adapters for the floe execution framework",
  "type": "module",
  "bin": {
    "floe-runtime": "./src/server.ts"
  },
  "scripts": {
    "start": "bun run src/server.ts",
    "dev": "bun --watch run src/server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "bun-types": "^1.3.11"
  },
  "peerDependencies": {
    "@openai/codex-sdk": "*",
    "@anthropic-ai/claude-agent-sdk": "*",
    "@github/copilot-sdk": "*"
  },
  "peerDependenciesMeta": {
    "@openai/codex-sdk": {
      "optional": true
    },
    "@anthropic-ai/claude-agent-sdk": {
      "optional": true
    },
    "@github/copilot-sdk": {
      "optional": true
    }
  }
}
