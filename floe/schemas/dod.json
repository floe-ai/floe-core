{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://floe.ai/schemas/dod.json",
  "title": "Definition of Done",
  "description": "Project-level Definition of Done criteria loaded by the floe runtime and injected into reviewer and implementer sessions.",
  "type": "object",
  "required": ["version", "criteria"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Schema version for forward compatibility"
    },
    "criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "category", "description", "severity"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "description": "Unique kebab-case identifier for this criterion"
          },
          "category": {
            "type": "string",
            "enum": ["quality", "correctness", "security", "documentation", "architecture"],
            "description": "Category grouping for the criterion"
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable description of what must be true"
          },
          "severity": {
            "type": "string",
            "enum": ["required", "recommended"],
            "description": "Whether this criterion is mandatory or advisory"
          }
        },
        "additionalProperties": false
      }
    },
    "notes": {
      "type": "string",
      "description": "Optional free-text notes about this DoD configuration"
    }
  },
  "additionalProperties": false
}
