{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://floe.ai/schemas/review.json",
  "title": "Review",
  "description": "A rolling review object for an active feature. One per active feature in v1.",
  "type": "object",
  "required": ["id", "target_type", "target_id", "status", "outcome", "created_at"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^rev-[a-z0-9-]+$"
    },
    "target_type": {
      "type": "string",
      "enum": ["feature", "epic", "release"],
      "description": "What this review evaluates"
    },
    "target_id": {
      "type": "string",
      "description": "ID of the artefact being reviewed"
    },
    "status": {
      "type": "string",
      "enum": ["open", "resolved", "superseded"]
    },
    "outcome": {
      "type": "string",
      "enum": ["pass", "fail", "blocked", "needs_replan", "pending"]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "severity": { "type": "string", "enum": ["critical", "major", "minor", "info"] },
          "description": { "type": "string" },
          "status": { "type": "string", "enum": ["open", "fixed", "wont_fix", "deferred"] },
          "added_at": { "type": "string", "format": "date-time" },
          "resolved_at": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "severity", "description", "status"]
      },
      "default": []
    },
    "required_actions": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "Concrete actions required before the review can pass"
    },
    "reviewer_session_id": {
      "type": "string",
      "description": "Optional session identifier for the reviewer"
    },
    "approach_proposal": {
      "type": "object",
      "description": "Pre-code alignment: implementer proposes execution approach; reviewer evaluates before coding begins",
      "properties": {
        "proposal": {
          "type": "string",
          "description": "Implementer's proposed execution approach for this feature"
        },
        "proposed_at": {
          "type": "string",
          "format": "date-time"
        },
        "verdict": {
          "type": "string",
          "enum": ["approved", "rejected", "escalated", "pending"],
          "default": "pending"
        },
        "verdict_rationale": {
          "type": "string",
          "description": "Reviewer's reasoning for the verdict"
        },
        "verdict_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["proposal", "proposed_at", "verdict"],
      "additionalProperties": false
    },
    "resolution_thread": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from": { "type": "string", "enum": ["implementer", "reviewer"] },
          "kind": { "type": "string", "enum": ["revised_approach", "counter_proposal", "clarification", "objection", "acceptance"] },
          "message": { "type": "string" },
          "requested_action": { "type": ["string", "null"], "enum": ["re_evaluate", "revise_approach", "provide_detail", "approve", null] },
          "status": { "type": "string", "enum": ["pending", "addressed", "superseded"], "default": "pending" },
          "at": { "type": "string", "format": "date-time" }
        },
        "required": ["from", "kind", "message", "status", "at"]
      },
      "default": []
    },
    "linked_summary_ids": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "resolved_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
