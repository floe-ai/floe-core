{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://floe.ai/schemas/note.json",
  "title": "Note",
  "description": "A pre-planning inbox item. Not a backlog item. Captures emerging ideas, concerns, references.",
  "type": "object",
  "required": ["id", "created_at", "source", "kind", "summary", "status"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^note-[a-z0-9-]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "description": "Where this note came from, e.g. user-chat, review, planning"
    },
    "kind": {
      "type": "string",
      "enum": ["idea", "concern", "contradiction", "question", "reference", "observation"]
    },
    "summary": {
      "type": "string",
      "description": "Concise structured summary of the note"
    },
    "raw_content": {
      "type": "string",
      "description": "Original wording or source material if helpful to preserve"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "How confident the capturer is that this note is valuable"
    },
    "related_release_id": { "type": "string" },
    "related_epic_id": { "type": "string" },
    "related_feature_id": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["url", "path", "snippet"] },
          "value": { "type": "string" },
          "label": { "type": "string" }
        },
        "required": ["type", "value"]
      },
      "default": [],
      "description": "Paths, URLs, or snippets referenced by this note"
    },
    "status": {
      "type": "string",
      "enum": ["captured", "reviewed", "promoted", "discarded"]
    }
  },
  "additionalProperties": false
}
