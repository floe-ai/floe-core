{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://floe.ai/schemas/runtime-state.json",
  "title": "Runtime State",
  "description": "Operational pointers and transient control state. Lives under .floe/state/. Not the durable source of truth.",
  "type": "object",
  "required": ["mode"],
  "properties": {
    "active_release_id": {
      "type": "string",
      "description": "Currently active release"
    },
    "active_epic_id": {
      "type": "string",
      "description": "Currently active epic"
    },
    "active_feature_id": {
      "type": "string",
      "description": "Currently active feature"
    },
    "mode": {
      "type": "string",
      "enum": ["initialise", "discover", "plan", "execute", "review", "idle"],
      "description": "Current operational mode"
    },
    "blocker": {
      "type": "object",
      "properties": {
        "class": {
          "type": "string",
          "enum": [
            "missing_context", "ambiguous_requirement", "architecture_conflict",
            "environment_issue", "flaky_test", "dependency_not_ready",
            "feature_too_large", "implementation_error", "unexpected_regression",
            "user_decision_required", "scope_change_required"
          ]
        },
        "description": { "type": "string" },
        "since": { "type": "string", "format": "date-time" }
      },
      "required": ["class", "description"]
    },
    "continuation_preference": {
      "type": "string",
      "enum": ["stop_after_feature", "continue_within_epic", "continue_within_release"],
      "default": "stop_after_feature",
      "description": "User-adjustable continuation preference"
    },
    "worker_registry_path": {
      "type": "string",
      "description": "Path to the worker session registry file (relative to project root)",
      "default": ".floe/state/sessions.json"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
