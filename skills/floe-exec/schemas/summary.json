{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://floe.ai/schemas/summary.json",
  "title": "Summary",
  "description": "A durable record of what happened, what changed, what was learned, and what the next agent should know.",
  "type": "object",
  "required": ["id", "target_type", "target_id", "kind", "content", "created_at"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^sum-[a-z0-9-]+$"
    },
    "target_type": {
      "type": "string",
      "enum": ["feature", "epic", "release"],
      "description": "What this summary covers"
    },
    "target_id": {
      "type": "string",
      "description": "ID of the artefact being summarised"
    },
    "kind": {
      "type": "string",
      "enum": ["run", "handoff", "completion", "replan", "lesson"],
      "description": "What triggered this summary"
    },
    "content": {
      "type": "string",
      "description": "The summary text"
    },
    "what_happened": {
      "type": "string",
      "description": "Brief description of what was done"
    },
    "what_changed": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "Files or artefacts that were modified"
    },
    "what_was_learned": {
      "type": "string",
      "description": "Key takeaways or lessons"
    },
    "next_agent_guidance": {
      "type": "string",
      "description": "What the next agent picking this up should know"
    },
    "linked_review_ids": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "session_id": {
      "type": "string",
      "description": "Optional session identifier for the agent that wrote this"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
