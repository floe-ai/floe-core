{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://floe.ai/schemas/worker-session.json",
  "title": "Worker Session",
  "description": "A single worker session entry in the runtime session registry. Lives under .ai/state/sessions.json.",
  "type": "object",
  "required": ["id", "role", "provider", "status", "feature_id", "created_at"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique session identifier (e.g. sess-abc123)"
    },
    "role": {
      "type": "string",
      "enum": ["foreman", "planner", "implementer", "reviewer"],
      "description": "Which canonical role this worker is running"
    },
    "provider": {
      "type": "string",
      "enum": ["codex", "claude", "copilot", "mock"],
      "description": "Provider runtime backing this session"
    },
    "provider_session_id": {
      "type": "string",
      "description": "Provider-native session/thread ID (if available)"
    },
    "status": {
      "type": "string",
      "enum": ["starting", "active", "idle", "stopped", "failed"],
      "description": "Current lifecycle status"
    },
    "feature_id": {
      "type": "string",
      "description": "The feature this session is scoped to"
    },
    "epic_id": {
      "type": "string",
      "description": "The epic containing the feature (denormalised for convenience)"
    },
    "release_id": {
      "type": "string",
      "description": "The release containing the epic (denormalised for convenience)"
    },
    "role_content_path": {
      "type": "string",
      "description": "Path to the canonical role definition injected at session start"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "stopped_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_message_at": {
      "type": "string",
      "format": "date-time"
    },
    "error": {
      "type": "string",
      "description": "Last error message if status is failed"
    },
    "metadata": {
      "type": "object",
      "description": "Adapter-specific metadata (e.g. thread IDs, conversation history pointers)",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
