{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://floe.ai/schemas/epic.json",
  "title": "Epic",
  "description": "A coherent capability area or major stream of work inside a release.",
  "type": "object",
  "required": ["id", "release_id", "title", "status", "intent", "priority"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^epic-[a-z0-9-]+$",
      "description": "Unique epic identifier, e.g. epic-auth-flow"
    },
    "release_id": {
      "type": "string",
      "description": "Parent release ID"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "blocked", "completed", "cancelled"]
    },
    "intent": {
      "type": "string",
      "description": "What this epic achieves within the release"
    },
    "priority": {
      "type": "string",
      "enum": ["critical", "high", "normal", "low", "parked"]
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "IDs of other epics this depends on"
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "subsystem_hints": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "Major subsystems or areas this epic touches"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
